{
  "version": 2,
  "builds": [
    {
      "src": "src/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/main.py"
    }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1"
  },
  "publicRuntimeConfig": {
    "DATABASE_URL": "@database_url",
    "REDIS_URL": "@redis_url",
    "API_KEY": "@api_key",
    "JWT_SECRET": "@jwt_secret"
  }
}
